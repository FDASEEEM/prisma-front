# API URLs
# Todas las llamadas pasan por el BFF (prisma-bff) en :3010
VITE_BFF_URL=http://localhost:3010

# Backend del agente PRISMA (chat/stream)
# Dejar VITE_CHAT_API_URL vacío para que las peticiones usen URLs relativas
# y pasen siempre por el proxy de Vite (necesario para ngrok y para evitar CORS).
# Solo cambiar CHAT_BACKEND_URL según el entorno:
#   - Desarrollo local:  CHAT_BACKEND_URL=http://localhost:8000
#   - Con ngrok:         CHAT_BACKEND_URL=https://<tu-id>.ngrok-free.app
VITE_CHAT_API_URL=
CHAT_BACKEND_URL=http://localhost:8000

# Supabase
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
